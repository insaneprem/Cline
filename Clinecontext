    <div class="wordmark">⬡ Cline Masterclass</div>
    <div class="tagline">Advanced AI-Assisted Development</div>
  </div>
  <div class="nav-label">Core Concepts</div>
  <a class="nav-item active" href="#skills"><span class="nav-num">01</span><span class="nav-icon">🔌</span>Skills &amp; MCPs</a>
