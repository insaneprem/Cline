<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:      #080b12;
  --bg2:     #0d1120;
  --bg3:     #121828;
  --surface: #161e30;
  --border:  #1e2a42;
  --border2: #263348;
  --text:    #c8d6f0;
  --text2:   #8096b8;
  --text3:   #4e6080;
  --head:    #eaf1ff;
  --cyan:    #38d9f5;
  --cyan2:   #0fa8c7;
  --amber:   #f5a623;
  --amber2:  #c47d0c;
  --green:   #3dffa0;
  --red:     #ff5f7a;
  --purple:  #b48cf7;
  --r-sm: 6px; --r-md: 12px; --r-lg: 20px;
  --font-mono:    'JetBrains Mono', monospace;
  --font-display: 'Fraunces', serif;
  --font-body:    'DM Sans', sans-serif;
}

html { scroll-behavior: smooth; }

body {
  background: var(--bg); color: var(--text);
  font-family: var(--font-body); font-size: 16px; line-height: 1.7; overflow-x: hidden;
}

body::before {
  content: ''; position: fixed; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
  opacity: 0.022; pointer-events: none; z-index: 9999;
}

::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

/* LAYOUT */
.shell { display: grid; grid-template-columns: 260px 1fr; min-height: 100vh; }

/* SIDEBAR */
.sidebar {
  grid-row: 1 / -1; position: sticky; top: 0; height: 100vh; overflow-y: auto;
  background: var(--bg2); border-right: 1px solid var(--border);
  padding: 32px 0; display: flex; flex-direction: column;
}
.sidebar-logo { padding: 0 24px 28px; border-bottom: 1px solid var(--border); margin-bottom: 24px; }
.sidebar-logo .wordmark { font-family: var(--font-mono); font-size: 11px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--cyan); }
.sidebar-logo .tagline  { font-size: 12px; color: var(--text3); margin-top: 4px; line-height: 1.4; }
.nav-label { font-family: var(--font-mono); font-size: 9px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text3); padding: 0 24px 10px; }
.nav-item  { display: flex; align-items: center; gap: 12px; padding: 10px 24px; text-decoration: none; color: var(--text2); font-size: 13px; transition: all 0.2s; border-left: 2px solid transparent; }
.nav-item:hover  { color: var(--head); background: var(--surface); border-left-color: var(--cyan); }
.nav-item.active { color: var(--cyan); background: rgba(56,217,245,0.06); border-left-color: var(--cyan); }
.nav-num  { font-family: var(--font-mono); font-size: 10px; font-weight: 700; color: var(--text3); min-width: 18px; }
.nav-item.active .nav-num { color: var(--cyan2); }
.nav-icon { font-size: 16px; min-width: 20px; text-align: center; }
.sidebar-footer { margin-top: auto; padding: 24px; border-top: 1px solid var(--border); font-family: var(--font-mono); font-size: 10px; color: var(--text3); line-height: 1.8; }
.sidebar-footer span { color: var(--green); }

/* HERO */
.hero {
  position: relative; padding: 80px 72px 72px;
  border-bottom: 1px solid var(--border); overflow: hidden; background: var(--bg2);
}
.hero::before { content:''; position:absolute; top:-120px; right:-80px; width:600px; height:600px; background:radial-gradient(circle,rgba(56,217,245,0.07) 0%,transparent 65%); pointer-events:none; }
.hero::after  { content:''; position:absolute; bottom:-100px; left:40%; width:400px; height:400px; background:radial-gradient(circle,rgba(245,166,35,0.05) 0%,transparent 65%); pointer-events:none; }
.hero-grid-bg {
  position:absolute; inset:0;
  background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);
  background-size:40px 40px; opacity:0.18; pointer-events:none;
  mask-image:linear-gradient(to bottom,transparent,rgba(0,0,0,0.5) 30%,rgba(0,0,0,0.5) 70%,transparent);
}
.hero-eyebrow {
  display:inline-flex; align-items:center; gap:8px;
  font-family:var(--font-mono); font-size:11px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:var(--cyan);
  background:rgba(56,217,245,0.08); border:1px solid rgba(56,217,245,0.2);
  padding:6px 14px; border-radius:100px; margin-bottom:28px; animation:fadeUp 0.6s ease both;
}
.hero-eyebrow::before { content:''; width:6px; height:6px; border-radius:50%; background:var(--cyan); box-shadow:0 0 8px var(--cyan); animation:pulse 2s ease infinite; }
@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.3;} }
.hero h1 { font-family:var(--font-display); font-size:clamp(36px,5vw,62px); font-weight:900; color:var(--head); line-height:1.08; letter-spacing:-0.02em; max-width:700px; margin-bottom:24px; animation:fadeUp 0.6s 0.1s ease both; }
.hero h1 em { font-style:italic; color:var(--cyan); font-weight:300; }
.hero-intro { font-size:17px; color:var(--text2); max-width:620px; line-height:1.75; animation:fadeUp 0.6s 0.2s ease both; }
.hero-intro strong { color:var(--text); }
.hero-meta { display:flex; gap:32px; margin-top:40px; animation:fadeUp 0.6s 0.3s ease both; }
.meta-item { display:flex; flex-direction:column; gap:4px; }
.meta-val   { font-family:var(--font-mono); font-size:22px; font-weight:700; color:var(--head); }
.meta-label { font-size:11px; color:var(--text3); text-transform:uppercase; letter-spacing:0.1em; font-family:var(--font-mono); }
@keyframes fadeUp { from{opacity:0;transform:translateY(16px);} to{opacity:1;transform:translateY(0);} }

/* TOPIC SECTIONS */
.topic-section { padding:72px; border-bottom:1px solid var(--border); opacity:0; transform:translateY(20px); transition:opacity 0.6s ease,transform 0.6s ease; }
.topic-section.visible { opacity:1; transform:translateY(0); }
.topic-section:nth-child(even) { background:var(--bg2); }
.topic-header { display:flex; align-items:flex-start; gap:28px; margin-bottom:48px; }
.topic-number { font-family:var(--font-display); font-size:80px; font-weight:900; font-style:italic; line-height:1; color:transparent; -webkit-text-stroke:1px var(--border2); min-width:80px; margin-top:-8px; transition:-webkit-text-stroke 0.3s; user-select:none; }
.topic-section:hover .topic-number { -webkit-text-stroke-color:var(--cyan2); }
.topic-title-block { flex:1; }
.topic-badge { display:inline-flex; align-items:center; gap:6px; font-family:var(--font-mono); font-size:10px; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; padding:4px 12px; border-radius:100px; margin-bottom:12px; }
.badge-skills      { color:var(--cyan);   background:rgba(56,217,245,0.08);  border:1px solid rgba(56,217,245,0.2); }
.badge-rules       { color:var(--amber);  background:rgba(245,166,35,0.08);  border:1px solid rgba(245,166,35,0.2); }
.badge-workflow    { color:var(--green);  background:rgba(61,255,160,0.08);  border:1px solid rgba(61,255,160,0.2); }
.badge-hooks       { color:var(--purple); background:rgba(180,140,247,0.08); border:1px solid rgba(180,140,247,0.2); }
.badge-memory      { color:var(--cyan);   background:rgba(56,217,245,0.08);  border:1px solid rgba(56,217,245,0.2); }
.badge-checkpoints { color:var(--red);    background:rgba(255,95,122,0.08);  border:1px solid rgba(255,95,122,0.2); }
.topic-title { font-family:var(--font-display); font-size:clamp(24px,3vw,36px); font-weight:700; color:var(--head); line-height:1.15; letter-spacing:-0.01em; }

/* CARDS */
.subsections { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
.subsection-full { grid-column:1 / -1; }
.sub-card { background:var(--surface); border:1px solid var(--border); border-radius:var(--r-md); padding:24px 28px; transition:border-color 0.25s,transform 0.25s; }
.sub-card:hover { border-color:var(--border2); transform:translateY(-2px); }
.sub-heading { display:flex; align-items:center; gap:10px; font-family:var(--font-mono); font-size:11px; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:14px; }
.sh-what{color:var(--cyan);} .sh-why{color:var(--amber);} .sh-how{color:var(--green);} .sh-best{color:var(--purple);}
.sub-card p { font-size:14.5px; color:var(--text2); line-height:1.75; }
.sub-card p strong { color:var(--text); font-weight:500; }

/* STEPS */
.steps { display:flex; flex-direction:column; gap:22px; margin-top:4px; }
.step  { display:flex; gap:16px; align-items:flex-start; }
.step-num { flex-shrink:0; width:26px; height:26px; background:var(--bg3); border:1px solid var(--border2); border-radius:50%; font-family:var(--font-mono); font-size:11px; font-weight:700; color:var(--cyan); display:flex; align-items:center; justify-content:center; margin-top:2px; }
.step-body  { flex:1; }
.step-title { font-weight:500; color:var(--head); font-size:14px; margin-bottom:6px; }
.step-desc  { font-size:13.5px; color:var(--text2); line-height:1.7; }

/* UI NAVIGATION CALLOUT — replaces terminal blocks */
.ui-nav {
  background:#090e1c; border:1px solid var(--border2); border-left:3px solid var(--amber);
  border-radius:var(--r-sm); padding:14px 18px; margin:12px 0;
  font-size:13px; color:var(--text2); line-height:1.75;
}
.ui-nav + .ui-nav { margin-top:6px; }
.ui-nav-label { font-family:var(--font-mono); font-size:9px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:var(--amber); margin-bottom:7px; }
.crumb { display:inline-flex; align-items:center; gap:4px; font-family:var(--font-mono); font-size:11.5px; background:var(--surface); border:1px solid var(--border2); border-radius:4px; padding:2px 8px; color:var(--head); white-space:nowrap; }
.arrow { color:var(--text3); margin:0 2px; font-size:12px; }

/* CODE BLOCK */
.code-block { background:#050810; border:1px solid var(--border); border-radius:var(--r-sm); overflow:hidden; margin:14px 0; font-family:var(--font-mono); font-size:12.5px; }
.code-header { display:flex; align-items:center; justify-content:space-between; padding:8px 16px; background:var(--bg3); border-bottom:1px solid var(--border); }
.code-dots { display:flex; gap:6px; }
.code-dots span { width:10px; height:10px; border-radius:50%; }
.dot-r{background:#ff5f57;} .dot-y{background:#febc2e;} .dot-g{background:#28c840;}
.code-filename { font-size:11px; color:var(--text3); letter-spacing:0.05em; }
.code-body { padding:18px 20px; overflow-x:auto; line-height:1.75; color:var(--text2); }
.code-body .kw {color:#b48cf7;} .code-body .str{color:#98c97a;} .code-body .cm{color:#4e6080;font-style:italic;} .code-body .cn{color:var(--cyan);} .code-body .nb{color:var(--amber);}

/* IMAGE PLACEHOLDER */
.img-placeholder { background:var(--bg3); border:1px dashed var(--border2); border-radius:var(--r-md); padding:24px; margin:16px 0; display:flex; align-items:flex-start; gap:16px; }
.img-icon { font-size:26px; flex-shrink:0; }
.img-label { font-size:13px; color:var(--text3); font-family:var(--font-mono); line-height:1.6; }
.img-label strong { display:block; color:var(--text2); font-size:11px; letter-spacing:0.06em; text-transform:uppercase; margin-bottom:4px; }

/* BEST PRACTICES */
.bp-list { display:flex; flex-direction:column; gap:12px; margin-top:4px; }
.bp-item { display:flex; gap:12px; font-size:13.5px; color:var(--text2); line-height:1.65; }
.bp-dot  { color:var(--purple); font-family:var(--font-mono); font-weight:700; flex-shrink:0; margin-top:2px; }
.bp-item strong { color:var(--text); }

/* CHIP */
.chip { display:inline-block; font-family:var(--font-mono); font-size:11.5px; background:var(--bg3); border:1px solid var(--border2); border-radius:4px; padding:1px 7px; color:var(--cyan); }

/* SUMMARY */
.summary-section { padding:72px; background:var(--bg2); border-bottom:1px solid var(--border); }
.summary-section h2 { font-family:var(--font-display); font-size:34px; font-weight:700; color:var(--head); margin-bottom:8px; }
.summary-section .sub { color:var(--text2); font-size:15px; margin-bottom:40px; }
.feature-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
.feature-card { background:var(--surface); border:1px solid var(--border); border-radius:var(--r-md); padding:24px; transition:all 0.25s; position:relative; overflow:hidden; }
.feature-card::before { content:''; position:absolute; top:0;left:0;right:0; height:2px; }
.fc-skills::before    { background:linear-gradient(90deg,var(--cyan),var(--cyan2)); }
.fc-rules::before     { background:linear-gradient(90deg,var(--amber),var(--amber2)); }
.fc-workflow::before  { background:linear-gradient(90deg,var(--green),#27b870); }
.fc-hooks::before     { background:linear-gradient(90deg,var(--purple),#8b5cf6); }
.fc-memory::before    { background:linear-gradient(90deg,var(--cyan),var(--purple)); }
.fc-checkpoints::before { background:linear-gradient(90deg,var(--red),#c73058); }
.feature-card:hover   { border-color:var(--border2); transform:translateY(-3px); box-shadow:0 12px 32px rgba(0,0,0,0.3); }
.fc-icon { font-size:28px; margin-bottom:14px; }
.fc-name { font-family:var(--font-mono); font-size:12px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--head); margin-bottom:8px; }
.fc-desc { font-size:13px; color:var(--text2); line-height:1.6; }

/* FOOTER */
.page-footer { padding:48px 72px; display:flex; align-items:center; justify-content:space-between; background:var(--bg); }
.footer-left { font-family:var(--font-mono); font-size:12px; color:var(--text3); line-height:1.8; }
.footer-left span { color:var(--green); }
.footer-badge { display:inline-flex; align-items:center; gap:8px; font-family:var(--font-mono); font-size:11px; color:var(--text2); background:var(--surface); border:1px solid var(--border); padding:8px 18px; border-radius:100px; }

@media (max-width:900px) {
  .shell { grid-template-columns:1fr; } .sidebar { display:none; }
  .hero,.topic-section,.summary-section,.page-footer { padding:40px 28px; }
  .subsections { grid-template-columns:1fr; } .feature-grid { grid-template-columns:1fr 1fr; }
}
@media (max-width:560px) { .feature-grid{grid-template-columns:1fr;} .hero-meta{flex-wrap:wrap;gap:20px;} }
</style>
</head>

